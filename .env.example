# Environment: "dev" or "prod"
APP_ENV="dev"

# Required (generate long random values)
APP_SERVER_SECRET="replace-with-long-random-secret"

# Recommended
APP_PEPPER="replace-with-long-random-pepper"

# Optional
APP_HOST="127.0.0.1"
APP_PORT="8080"
APP_POW_BITS="18"
# Cookies:
# - APP_COOKIE_SECURE="0" is ONLY for local/dev over plain HTTP.
# - For production behind HTTPS, set APP_COOKIE_SECURE="1" so cookies get the Secure flag and HSTS is enabled.
APP_COOKIE_SECURE="0"
APP_PW_TAG_KEY="optional-separate-key-for-password-reuse-tags"
